generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id             String    @id @default(cuid())
  style          String
  inputVideoUrl  String
  outputVideoUrl String?
  thumbnailUrl   String?
  petName        String?
  status         String    @default("QUEUED") // JobStatus: QUEUED | PROCESSING | COMPLETED | FAILED
  errorMessage   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
